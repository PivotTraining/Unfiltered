# ---------- Stripe (required for checkout) ----------
# Test keys start with sk_test_ / pk_test_; live keys with sk_live_ / pk_live_.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret from Stripe -> Developers -> Webhooks (whsec_...).
# Required for /api/webhook to accept events.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional Stripe features
# Set to "true" to turn on Stripe Tax (must be activated in dashboard first).
STRIPE_TAX_ENABLED=false
# Comma-separated Stripe shipping rate IDs (shr_...) to offer at checkout.
STRIPE_SHIPPING_RATES=

# ---------- Site URL ----------
# Used to build the return_url. Vercel sets host headers automatically;
# only override for local dev (e.g. http://localhost:3000) or a custom domain.
PUBLIC_BASE_URL=

# ---------- Email notifications (optional) ----------
# Resend API key (https://resend.com). If unset, order emails are skipped.
RESEND_API_KEY=
# Where order alerts get sent.
ORDER_NOTIFY_EMAIL=hello@unfiltered.shop
# Verified sender (must be a domain you've verified in Resend).
ORDER_NOTIFY_FROM=orders@unfiltered.shop

# ---------- Supabase order storage (optional) ----------
# If both are set, orders are written to the `orders` table and stock is
# read/decremented from the `inventory` table. See LAUNCH.md for the schema.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
