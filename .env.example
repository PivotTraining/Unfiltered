# Stripe secret key (TEST mode starts with sk_test_...). Server-side only — never commit the real value.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe publishable key (TEST mode starts with pk_test_...). Safe to expose to the browser.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Public base URL of the site (used for the checkout return URL). Vercel sets this automatically in prod;
# set it for local dev, e.g. http://localhost:3000
PUBLIC_BASE_URL=
